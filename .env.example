# ── Neon DB ────────────────────────────────────────────────────────────────────
# Your personal branch connection string (set automatically by `pnpm db:branch`)
VITE_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# The shared main branch — preserved when db:branch runs so you can switch back
# NEON_MAIN_DATABASE_URL=postgresql://...

# ── Neon Management API (required for `pnpm db:branch`) ───────────────────────
# Generate at: https://console.neon.tech/app/settings/api-keys
NEON_API_KEY=your_neon_api_key_here

# Set automatically by db:branch — or find it in the Neon console URL
# NEON_PROJECT_ID=your_project_id
# NEON_BRANCH_NAME=dev/your-name
# NEON_BRANCH_ID=br-...
